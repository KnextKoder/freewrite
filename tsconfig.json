{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "app",
    "outDir": "generated",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "sourceMap": false
  },
  "include": ["app/**/*.ts"],
  "exclude": ["node_modules", "dist", "generated"]
}
