{
  "name": "freewrite",
  "version": "1.0.1",
  "description": "A simple app to freewrite",
  "repository": {
    "type": "git",
    "url": "https://github.com/knextkoder/freewrite"
  },
  "main": "generated/main.js",
  "scripts": {
    "start": "npm run build:assets && electron .",
    "dev": "npm run build:assets && concurrently -k \"npm:watch:ts\" \"npm:watch:css\" \"npm:watch:electron\"",
    "build": "npm run build:assets && electron-builder --win",
    "build:mac": "npm run build:assets && electron-builder --mac",
    "build:linux": "npm run build:assets && electron-builder --linux",
    "build:all": "npm run build:assets && electron-builder -mwl",
    "dist": "npm run build:assets && electron-builder --win",
    "pack": "npm run build:assets && electron-builder --dir",
    "make": "npm run build:assets && electron-builder --win",
    "clean:generated": "node -e \"require('fs').rmSync('generated',{recursive:true,force:true})\"",
    "build:assets": "npm run clean:generated && npm run build:ts && npm run build:css",
    "build:ts": "tsc",
    "watch:ts": "tsc -w --preserveWatchOutput",
    "build:css": "tailwindcss -i ./app/tailwind.css -o ./generated/styles.css --minify",
    "watch:css": "tailwindcss -i ./app/tailwind.css -o ./generated/styles.css --watch",
    "watch:electron": "electronmon .",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.1",
    "concurrently": "^9.1.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "electronmon": "^2.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0",
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.freewrite.app",
    "productName": "Freewrite",
    "publish": [
      "github"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "icon": "assets/icon.ico"
    },
    "linux": {
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Freewrite-Portable-${version}.exe"
    },
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    }
  }
}
